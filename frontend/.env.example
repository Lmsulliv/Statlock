# Frontend environment variables (Vite). Copy to .env.local to override locally.
# Vite only exposes vars prefixed with VITE_ to the browser bundle.

# Local/dev management nav. When "true", the management screens (Accounts importer,
# Era manager) appear. This only applies when the API runs in local single-user mode
# (no DEADLOCK_BASE_URL). With Steam login configured, the app shows those screens to
# logged-in users instead and ignores this flag. Convenience only — the API enforces
# every write.
VITE_OWNER=true
