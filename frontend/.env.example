# Frontend environment variables (Vite). Copy to .env.local to override locally.
# Vite only exposes vars prefixed with VITE_ to the browser bundle.

# Interim owner gate (NOT authentication). When "true", the Era manager nav link
# and /eras route are shown; otherwise they're hidden. This is convenience only
# — the API enforces the gate by returning 403 on the confirm/dismiss endpoints
# unless the backend's DEADLOCK_OWNER flag is also set. Both are stopgaps until a
# real login exists.
VITE_OWNER=true
